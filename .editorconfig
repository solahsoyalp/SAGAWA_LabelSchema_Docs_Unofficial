root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# CSV samples intentionally keep CRLF (e飛伝Ⅲ / Shift_JIS convention)
[*.csv]
end_of_line = crlf
trim_trailing_whitespace = false

[*.md]
trim_trailing_whitespace = false
